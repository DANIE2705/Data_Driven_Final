@page
@model Data_Driven_Final.Pages.Products.IndexModel

<h2>Products</h2>

<a asp-page="Create" class="btn btn-primary mb-3">Create New Product</a>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Price</th>
            <th>Category</th>
            <th>In Stock</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var p in Model.Products)
        {
            <tr>
                <td>@p.Name</td>
                <td>@(p.Price?.ToString("C") ?? "—")</td>
                <td>@(p.Category ?? "—")</td>
                <td>@(p.InStock == true ? "Yes" : "No")</td>
                <td>
                    <a asp-page="Details" asp-route-id="@p.Id" class="btn btn-info btn-sm">Details</a>
                    <a asp-page="Edit" asp-route-id="@p.Id" class="btn btn-warning btn-sm">Edit</a>
                    <a asp-page="Delete" asp-route-id="@p.Id" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
