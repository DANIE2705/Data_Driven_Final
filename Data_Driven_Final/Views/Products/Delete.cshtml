@model Data_Driven_Final.Models.Product

<h2>Delete Product</h2>

<h4>Are you sure you want to delete this product?</h4>
<hr />

<div>
    <dl class="row">
        <dt class="col-sm-2">Name</dt>
        <dd class="col-sm-10">@Model.Name</dd>

        <dt class="col-sm-2">Price</dt>
        <dd class="col-sm-10">@Model.Price</dd>

        <dt class="col-sm-2">Category</dt>
        <dd class="col-sm-10">@Model.Category</dd>

        <dt class="col-sm-2">Categories</dt>
        <dd class="col-sm-10">
            @if (Model.Categories != null)
            {
                @string.Join(", ", Model.Categories)
            }
        </dd>

        <dt class="col-sm-2">In Stock</dt>
        <dd class="col-sm-10">@((Model.InStock == true) ? "Yes" : "No")</dd>

        <dt class="col-sm-2">Tags</dt>
        <dd class="col-sm-10">
            @if (Model.Tags != null)
            {
                @string.Join(", ", Model.Tags)
            }
        </dd>

        <dt class="col-sm-2">Material</dt>
        <dd class="col-sm-10">@Model.Material</dd>

        <dt class="col-sm-2">Capacity (oz)</dt>
        <dd class="col-sm-10">@Model.CapacityOz</dd>

        <dt class="col-sm-2">Warranty</dt>
        <dd class="col-sm-10">@Model.WarrantyMonths</dd>

        <dt class="col-sm-2">Specifications</dt>
        <dd class="col-sm-10">
            @if (Model.Specifications != null)
            {
                if (Model.Specifications.Color != null)
                {
                    <div><strong>Color:</strong> @Model.Specifications.Color</div>
                }
                if (Model.Specifications.BatteryLife != null)
                {
                    <div><strong>Battery:</strong> @Model.Specifications.BatteryLife</div>
                }
                if (Model.Specifications.Connection != null)
                {
                    <div><strong>Connection:</strong> @Model.Specifications.Connection</div>
                }
                if (Model.Specifications.Processor != null)
                {
                    <div><strong>CPU:</strong> @Model.Specifications.Processor.Brand @Model.Specifications.Processor.Model (@Model.Specifications.Processor.Cores cores)</div>
                }
                if (Model.Specifications.Graphics != null)
                {
                    <div><strong>GPU:</strong> @Model.Specifications.Graphics.Brand @Model.Specifications.Graphics.Model</div>
                }
                if (Model.Specifications.MemoryGB != null)
                {
                    <div><strong>Memory:</strong> @Model.Specifications.MemoryGB GB</div>
                }
                if (Model.Specifications.Storage != null)
                {
                    <div><strong>Storage:</strong> @Model.Specifications.Storage.Type @Model.Specifications.Storage.CapacityGB GB</div>
                }
            }
        </dd>

        <dt class="col-sm-2">Reviews</dt>
        <dd class="col-sm-10">
            @if (Model.Reviews != null)
            {
                foreach (var r in Model.Reviews)
                {
                    <div>⭐ @r.Rating — @r.Comment</div>
                }
            }
        </dd>
    </dl>
</div>

<form method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a class="btn btn-secondary" asp-action="Index">Cancel</a>
</form>
