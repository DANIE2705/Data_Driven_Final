@model Data_Driven_Final.Models.Product

<h2>Create Product</h2>

<form method="post">
    <div class="form-group">
        <label>Name</label>
        <input asp-for="Name" class="form-control" />
    </div>

    <div class="form-group">
        <label>Price</label>
        <input asp-for="Price" class="form-control" />
    </div>

    <div class="form-group">
        <label>Category</label>
        <input asp-for="Category" class="form-control" />
    </div>

    <div class="form-group">
        <label>In Stock</label>
        <input asp-for="InStock" type="checkbox" class="form-check-input" />
    </div>

    <div class="form-group">
        <label>Tags (comma-separated)</label>
        <input name="TagsInput" class="form-control" />
    </div>

    <h4>Specifications</h4>

    <div class="form-group">
        <label>Color</label>
        <input asp-for="Specifications.Color" class="form-control" />
    </div>

    <div class="form-group">
        <label>Battery Life</label>
        <input asp-for="Specifications.BatteryLife" class="form-control" />
    </div>

    <div class="form-group">
        <label>Connection</label>
        <input asp-for="Specifications.Connection" class="form-control" />
    </div>

    <button type="submit" class="btn btn-success mt-3">Create</button>
    <a class="btn btn-secondary mt-3" asp-action="Index">Back</a>
</form>

